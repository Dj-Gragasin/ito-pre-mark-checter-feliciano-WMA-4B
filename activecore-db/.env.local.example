NODE_ENV=development

TRUST_PROXY=0

DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SSL_CA=

# ==================== AUTH ====================
JWT_SECRET=

# ==================== CORS / URLS ====================
# Comma-separated list
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ==================== RATE LIMITING ====================
AUTH_RATE_LIMIT_MAX=20
GENERAL_RATE_LIMIT_MAX=300
REGISTER_RATE_LIMIT_MAX=10

# ==================== PAYPAL ====================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox


# ==================== OPENAI (Optional) ====================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ==================== EMAIL (Optional) ====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# ==================== NOTIFICATIONS ====================
INACTIVE_NOTIFY_DAYS=3

# ==================== MONITORING / LOGGING ====================
SENTRY_DSN=
LOG_LEVEL=info
